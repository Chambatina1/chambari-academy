generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STUDENT") // TEACHER or STUDENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes   Class[]  @relation("TeacherClasses")
  progress  Progress[]
}

model Class {
  id            String   @id @default(cuid())
  teacherId     String
  title         String
  topic         String
  content       String
  documentUrl   String   @default("")
  documentName  String   @default("")
  videoUrl      String   @default("")
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher      User         @relation("TeacherClasses", fields: [teacherId], references: [id])
  exercises    Exercise[]
  progress     Progress[]
  liveSessions LiveSession[]
}

model LiveSession {
  id          String       @id @default(cuid())
  classId     String
  teacherId   String       @default("default-teacher")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  annotations Annotation[]
}

model Annotation {
  id          String       @id @default(cuid())
  sessionId   String
  content     String
  type        String       @default("message") // "message", "highlight", "alert"
  createdAt   DateTime     @default(now())

  session     LiveSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Exercise {
  id            String   @id @default(cuid())
  classId       String
  type          String
  question      String
  options       String
  correctAnswer String
  explanation   String
  orderIndex    Int      @default(0)

  class         Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model Progress {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  score       Int      @default(0)
  totalQuestions Int    @default(0)
  completed   Boolean  @default(false)
  answers     String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     User     @relation(fields: [studentId], references: [id])
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
}
